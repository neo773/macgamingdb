{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/macgamingdb-emails",
    "packages/macgamingdb-server",
    "packages/macgamingdb-ui",
    "packages/macgamingdb-shared"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:server": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node --watch packages/macgamingdb-server/dist/main.js",
    "db:push": "bunx drizzle-kit push",
    "db:push:prod": "NODE_ENV=production bunx --env-file=.env.prod drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed:mac-configs": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js populate-mac-configs --seed",
    "scrape:mac-configs": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js populate-mac-configs --scrape",
    "populate:aggregated-performance": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js backfill-aggregated-performance",
    "populate:review-count": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js backfill-review-counts",
    "backfill:game-slugs": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js backfill-game-slugs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "bunx prettier --write ./src ./scripts",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "migrate:database": "bun run build:api && env $(grep -v \"^#\" .env.local | xargs) node packages/macgamingdb-server/dist/command/main.js migrate-database",
    "test:production-migration": "bun --bun scripts/test-production-migration.ts",
    "build:api": "bunx tsc -p packages/macgamingdb-shared/tsconfig.json && bunx tsc -p packages/macgamingdb-emails/tsconfig.build.json && bunx tsc -p packages/macgamingdb-server/tsconfig.build.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "@better-auth/expo": "^1.4.13",
    "@libsql/client": "^0.17.0",
    "macgamingdb-emails": "workspace:*",
    "macgamingdb-server": "workspace:*",
    "macgamingdb-ui": "workspace:*",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/components": "^0.0.36",
    "@sniptt/guards": "^0.2.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/date-fns": "^2.6.3",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "better-auth": "^1.2.5",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "expo-network": "^8.0.8",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "jose": "^6.1.3",
    "linkedom": "^0.18.9",
    "lucide-react": "^0.532.0",
    "motion": "^12.23.11",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.2.0",
    "sonner": "^2.0.3",
    "steam-signin": "^1.0.5",
    "superjson": "^2.2.2",
    "trpc-to-openapi": "2.4.0",
    "tw-animate-css": "^1.2.4",
    "ua-parser-js": "^2.0.3",
    "use-debounce": "^10.0.5",
    "zod": "^3.25.0",
    "zod-openapi": "4.2.4",
    "macgamingdb-shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250420.0",
    "@eslint/js": "^9.27.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/bun": "^1.2.20",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.16",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.27.0",
    "eslint-config-next": "16.1.1",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.0.16"
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "next": "$next",
    "@radix-ui/react-accordion": "1.2.16",
    "better-auth": "1.4.7",
    "@better-auth/expo": "1.4.13"
  }
}
